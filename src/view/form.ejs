<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create User</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>
    <ul>
        <li><a href="/">Home</a></li>
        <li><a class="active" href="">Create user</a></li>
    </ul>

    <div id="form" class="d-flex justify-content-center align-items-center">
        <form action="/create-user" method="POST">
            <fieldset>
                <legend>Create New User</legend>

                <div class="form-control">
                    <div>
                        <label class="form-label" for="em">Email: </label>
                        <input type="text" name="email" class="form-control" id="em">
                        <span class="text-danger" id="emErr"></span>
                    </div>

                    <div>
                        <label class="form-label" for="ten">Name: </label>
                        <input type="text" name="name" id="ten" class="form-control">
                        <span class="text-danger" id="tenErr"></span>
                    </div>

                    <div>
                        <label class="form-label" for="tp">City: </label>
                        <input type="text" name="city" class="form-control" id="tp">
                        <span class="text-danger" id="tpErr"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-info m-2" id="nut">Save</button>
            </fieldset>
        </form>
    </div>
    <script>
        function checkName() {
            var name = $("#ten").val();
            var regName = /^[a-zA-Z]+(\s[a-zA-Z]+)+$/;

            if (name === "" || !name) {
                $("#tenErr").text("Nhập tên");
                $("#ten").focus();
                return false;
            } else {
                if (!regName.test(name)) {
                    $("#tenErr").text("Nhập 2 từ");
                    return false;
                }
            }
            return true;
        }

        function checkEmail() {
            var email = $("#em").val();
            var regEmail = /^[a-zA-Z0-9]+(@gmail\.com)$/;

            if (email === "" || !email) {
                $("#emErr").text("Nhập email");
                $("#em").focus();
                return false;
            } else {
                if (!regEmail.test(email)) {
                    $("#emErr").text("Định dạng: abc@gmail.com");
                    return false;
                }
            }
            return true;
        }

        function checkCity() {
            var tp = $("#tp").val();
            if (tp === "" || !tp) {
                $("#tpErr").text("Nhập city");
                $("#tp").focus();
                return false;
            }
            return true;
        }

        $(document).ready(function () {
            $("#ten").blur(function (e) {
                e.preventDefault();
                if (checkName()) {
                    $("#tenErr").text("");
                }
            });

            $("#em").blur(function (e) {
                e.preventDefault();
                if (checkEmail()) {
                    $("#emErr").text("");
                }
            });

            $("#tp").blur(function (e) {
                e.preventDefault();
                if (checkCity()) {
                    $("#tpErr").text("");
                }
            });

            $("#nut").click(function (e) {
                if (!(checkName() && checkEmail() && checkCity())) {
                    e.preventDefault();
                } else {
                    $("#tpErr").text("");
                    $("#emErr").text("");
                    $("#tenErr").text("");
                }
            });
        });
    </script>
</body>

</html>